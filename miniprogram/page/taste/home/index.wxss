@import "../common/theme-soft-morning.wxss";

page {
  background: #faf6f0;
  display: block;
}

.hero-btn {
  margin-top: 22rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
  color: #4c4038;
  font-weight: 600;
}

.section-link {
  font-size: 24rpx;
  color: #c58d61;
}

.record-item {
  background: #fffdf9;
  border-radius: 20rpx;
  border: 2rpx solid #f0e5d8;
  padding: 16rpx;
  margin-top: 14rpx;
}

.record-cover {
  width: 100%;
  height: 220rpx;
  border-radius: 16rpx;
}

.record-body {
  margin-top: 12rpx;
}

.record-title {
  font-size: 30rpx;
  color: #4c4038;
  font-weight: 500;
}

.record-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
  flex-wrap: wrap;
}

.mood-tag {
  background: #e7c7bc;
}

.record-date {
  font-size: 24rpx;
  color: #8c786a;
}
