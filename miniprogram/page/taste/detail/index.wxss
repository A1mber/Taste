@import "../common/theme-soft-morning.wxss";

page {
  background: #faf6f0;
  display: block;
}

.mini {
  font-size: 40rpx;
}

.detail-cover {
  width: 100%;
  height: 340rpx;
  border-radius: 20rpx;
  margin-top: 12rpx;
}

.detail-cover:first-child {
  margin-top: 0;
}

.detail-meta {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.mood {
  background: #e7c7bc;
}

.appetite {
  background: #e7c978;
}

.detail-date,
.detail-food {
  margin-top: 14rpx;
  color: #8c786a;
  font-size: 26rpx;
}

.detail-note {
  margin-top: 20rpx;
  color: #4c4038;
  font-size: 30rpx;
  line-height: 1.8;
}
